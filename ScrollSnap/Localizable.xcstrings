    "Please select your Desktop folder to grant ScrollSnap permission to save screenshots there." : {
      "comment" : "Prompt asking the user to choose the Desktop folder for screenshot save access.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle bitte den Ordner „Schreibtisch“ aus, damit ScrollSnap dort Bildschirmfotos speichern darf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please select your Desktop folder to grant ScrollSnap permission to save screenshots there."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecciona la carpeta Escritorio para permitir que ScrollSnap guarde allí las capturas de pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
